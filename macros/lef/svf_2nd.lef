VERSION 5.7 ;
BUSBITCHARS "[]" ;
DIVIDERCHAR "/" ;

MACRO svf_2nd
  CLASS BLOCK ;
  ORIGIN 0 0 ;
  FOREIGN svf_2nd 0 0 ;
  SIZE 64.000 BY 67.000 ;
  SYMMETRY X Y ;

  PIN vin
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 29.000 0.500 33.000 ;
    END
  END vin

  PIN vout
    DIRECTION OUTPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 63.500 29.000 64.000 33.000 ;
    END
  END vout

  PIN sel0
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 5.500 0.500 7.500 ;
    END
  END sel0

  PIN sel1
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 14.500 0.500 16.500 ;
    END
  END sel1

  PIN sc_clk
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 43.000 0.500 45.000 ;
    END
  END sc_clk

  PIN q0
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 21.700 0.500 22.300 ;
    END
  END q0

  PIN q1
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 23.200 0.500 23.800 ;
    END
  END q1

  PIN q2
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 24.700 0.500 25.300 ;
    END
  END q2

  PIN q3
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 26.200 0.500 26.800 ;
    END
  END q3

  PIN VDD
    DIRECTION INOUT ;
    USE POWER ;
    PORT
      LAYER Metal3 ;
        RECT 0.000 65.000 64.000 67.000 ;
      LAYER TopMetal1 ;
        RECT 0.000 65.100 64.000 66.900 ;
    END
  END VDD

  PIN VSS
    DIRECTION INOUT ;
    USE GROUND ;
    PORT
      LAYER Metal3 ;
        RECT 0.000 0.000 64.000 2.000 ;
      LAYER TopMetal1 ;
        RECT 0.000 0.000 64.000 1.360 ;
    END
  END VSS

  OBS
    LAYER Metal1 ;
      RECT 0.500 0.500 63.500 66.500 ;
    LAYER Metal2 ;
      RECT 0.500 0.500 63.500 66.500 ;
    LAYER Metal3 ;
      RECT 0.500 2.000 63.500 65.000 ;
    LAYER Metal4 ;
      RECT 0.500 0.500 63.500 66.500 ;
    LAYER Metal5 ;
      RECT 0.500 0.500 63.500 66.500 ;
    LAYER TopMetal1 ;
      RECT 0.500 1.360 63.500 65.100 ;
  END

END svf_2nd

END LIBRARY
