VERSION 5.7 ;
BUSBITCHARS "[]" ;
DIVIDERCHAR "/" ;

MACRO r2r_dac_8bit
  CLASS BLOCK ;
  ORIGIN 0 0 ;
  FOREIGN r2r_dac_8bit 0 0 ;
  SIZE 36.000 BY 38.000 ;
  SYMMETRY X Y ;

  PIN d0
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 2.000 0.500 3.000 ;
    END
  END d0

  PIN d1
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 5.500 0.500 6.500 ;
    END
  END d1

  PIN d2
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 9.000 0.500 10.000 ;
    END
  END d2

  PIN d3
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 12.500 0.500 13.500 ;
    END
  END d3

  PIN d4
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 16.000 0.500 17.000 ;
    END
  END d4

  PIN d5
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 19.500 0.500 20.500 ;
    END
  END d5

  PIN d6
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 23.000 0.500 24.000 ;
    END
  END d6

  PIN d7
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 26.500 0.500 27.500 ;
    END
  END d7

  PIN vout
    DIRECTION OUTPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 35.500 17.500 36.000 18.500 ;
    END
  END vout

  PIN vdd
    DIRECTION INOUT ;
    USE POWER ;
    PORT
      LAYER Metal3 ;
        RECT 0.000 36.500 36.000 38.000 ;
    END
    PORT
      LAYER Metal4 ;
        RECT 0.000 36.500 36.000 38.000 ;
    END
    PORT
      LAYER Metal5 ;
        RECT 0.000 36.500 36.000 38.000 ;
    END
    PORT
      LAYER TopMetal1 ;
        RECT 0.000 36.530 36.000 37.970 ;
    END
  END vdd

  PIN vss
    DIRECTION INOUT ;
    USE GROUND ;
    PORT
      LAYER Metal3 ;
        RECT 0.000 0.000 36.000 1.500 ;
    END
    PORT
      LAYER Metal4 ;
        RECT 0.000 0.000 36.000 1.500 ;
    END
    PORT
      LAYER Metal5 ;
        RECT 0.000 0.000 36.000 1.500 ;
    END
    PORT
      LAYER TopMetal1 ;
        RECT 0.000 0.030 36.000 1.470 ;
    END
  END vss

  OBS
    LAYER Metal1 ;
      RECT 0.500 0.500 35.500 37.500 ;
    LAYER Metal2 ;
      RECT 0.500 0.500 35.500 37.500 ;
  END

END r2r_dac_8bit

END LIBRARY
