VERSION 5.7 ;
BUSBITCHARS "[]" ;
DIVIDERCHAR "/" ;

MACRO r2r_dac_8bit
  CLASS BLOCK ;
  ORIGIN 0 0 ;
  FOREIGN r2r_dac_8bit 0 0 ;
  SIZE 36.000 BY 30.000 ;
  SYMMETRY X Y ;

  PIN d0
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 1.800 0.500 2.400 ;
    END
  END d0

  PIN d1
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 2.640 0.500 3.240 ;
    END
  END d1

  PIN d2
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 3.480 0.500 4.080 ;
    END
  END d2

  PIN d3
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 4.320 0.500 4.920 ;
    END
  END d3

  PIN d4
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 5.160 0.500 5.760 ;
    END
  END d4

  PIN d5
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 6.000 0.500 6.600 ;
    END
  END d5

  PIN d6
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 6.840 0.500 7.440 ;
    END
  END d6

  PIN d7
    DIRECTION INPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 0.000 7.680 0.500 8.280 ;
    END
  END d7

  PIN vout
    DIRECTION OUTPUT ;
    USE SIGNAL ;
    PORT
      LAYER Metal2 ;
        RECT 35.500 14.500 36.000 15.500 ;
    END
  END vout

  PIN VDD
    DIRECTION INOUT ;
    USE POWER ;
    PORT
      LAYER Metal3 ;
        RECT 0.000 28.500 36.000 30.000 ;
    END
  END VDD

  PIN VSS
    DIRECTION INOUT ;
    USE GROUND ;
    PORT
      LAYER Metal3 ;
        RECT 0.000 0.000 36.000 1.500 ;
    END
  END VSS

  OBS
    LAYER Metal1 ;
      RECT 0.500 0.500 35.500 29.500 ;
    LAYER Metal2 ;
      RECT 0.500 0.500 35.500 29.500 ;
    LAYER Metal3 ;
      RECT 0.500 1.500 35.500 28.500 ;
    LAYER TopMetal1 ;
      RECT 0.500 4.000 35.500 26.000 ;
  END

END r2r_dac_8bit

END LIBRARY
